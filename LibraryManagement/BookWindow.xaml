<Window x:Class="LibraryManagement.BookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryManagement"
        mc:Ignorable="d"
        Title="BookWindow" Height="623" Width="800">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <TextBlock Text="Название книги:" FontWeight="Bold"/>
                <TextBox x:Name="TitleTextBox" Margin="0,5,0,10" ToolTip="Введите полное название книги"/>

                <TextBlock Text="ISBN:" FontWeight="Bold"/>
                <TextBox x:Name="IsbnTextBox" Margin="0,5,0,10" ToolTip="Формат: 978-X-XXX-XXXXX-X"/>

                <TextBlock Text="Год издания:" FontWeight="Bold"/>
                <TextBox x:Name="YearTextBox" Margin="0,5,0,10"/>

                <TextBlock Text="Количество на складе:" FontWeight="Bold"/>
                <TextBox x:Name="CountTextBox" Margin="0,5,0,10"/>

                <TextBlock Text="Авторы:" FontWeight="Bold"/>
                <ListBox x:Name="AuthorsListBox" 
                     Height="100" 
                     Margin="0,5,0,10" 
                     DisplayMemberPath="FullName" 
                     SelectionMode="Multiple"/>

                <TextBlock Text="Жанры:" FontWeight="Bold"/>
                <ListBox x:Name="GenresListBox" 
                     Height="80" 
                     Margin="0,5,0,10" 
                     DisplayMemberPath="Name" 
                     SelectionMode="Multiple"/>

                <Button Content="Сохранить" Click="SaveButton_Click" Height="40" Margin="0,10,0,0" Background="#E1E1E1"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
