<Window x:Class="LibraryManagement.AddAuthorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый автор" Height="394" Width="413"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="20">
        <TextBlock Text="Фамилия:" FontWeight="Bold"/>
        <TextBox x:Name="LastNameBox" Margin="0,5,0,10"/>

        <TextBlock Text="Имя:" FontWeight="Bold"/>
        <TextBox x:Name="FirstNameBox" Margin="0,5,0,10"/>

        <TextBlock Text="Страна:" FontWeight="Bold"/>
        <TextBox x:Name="CountryBox" Margin="0,5,0,10"/>

        <TextBlock Text="Дата рождения:" FontWeight="Bold"/>
        <DatePicker x:Name="BirthDatePicker" Margin="0,5,0,15"/>

        <Button Content="Добавить" Height="35" Click="Add_Click" Background="#E1E1E1"/>
    </StackPanel>
</Window>